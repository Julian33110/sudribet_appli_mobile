<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Sudribet" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/surface_bg</item>
        <item name="android:statusBarColor">@color/background_blue</item>
    </style>

    <style name="Theme.Sudribet" parent="Base.Theme.Sudribet" />

    <!-- Transition animations -->
    <style name="SlideTransition" parent="Theme.Sudribet">
        <item name="android:windowAnimationStyle">@style/WindowAnimation.Slide</item>
    </style>
    <style name="WindowAnimation.Slide" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>
</resources>